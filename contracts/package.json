{
  "name": "polymer-bridge-contracts",
  "version": "1.0.0",
  "description": "Polymer Bridge smart contracts for Base and Plume networks",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:plume": "hardhat run scripts/deploy.ts --network plume",
    "set-peer:base": "hardhat run scripts/set-peer.ts --network base",
    "set-peer:plume": "hardhat run scripts/set-peer.ts --network plume",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
